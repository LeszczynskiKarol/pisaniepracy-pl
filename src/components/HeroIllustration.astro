---
// HeroIllustration — pisaniepracy.pl. Koncept: jedna praca (manuskrypt) → trzy ścieżki.
// Po lewej kartka pracy z piórem; po prawej trzy węzły (poradnik / dokument / AI),
// połączone krzywymi z dokumentem. Wizualizuje lejek: jeden proces, trzy drogi.
interface Props {
  variant?: "conceptual" | "minimal";
}
const { variant = "conceptual" } = Astro.props;
---

<div class="relative" aria-hidden="true">
  {variant === "conceptual" && (
    <svg viewBox="0 0 480 380" class="h-auto w-full" role="img" aria-label="Ilustracja: jedna praca, trzy ścieżki">
      <defs>
        <radialGradient id="hero-bg" cx="28%" cy="35%" r="75%">
          <stop offset="0%" stop-color="var(--color-accent)" stop-opacity="0.16" />
          <stop offset="100%" stop-color="var(--color-accent)" stop-opacity="0" />
        </radialGradient>
        <linearGradient id="hero-doc" x1="0" y1="0" x2="1" y2="1">
          <stop offset="0%" stop-color="var(--color-bg-elevated)" />
          <stop offset="100%" stop-color="var(--color-bg-subtle)" />
        </linearGradient>
        <linearGradient id="hero-accent" x1="0" y1="0" x2="1" y2="1">
          <stop offset="0%" stop-color="var(--color-accent)" />
          <stop offset="100%" stop-color="var(--color-accent-secondary)" />
        </linearGradient>
      </defs>

      <rect width="480" height="380" fill="url(#hero-bg)" />

      {/* Łączące krzywe: dokument → trzy węzły */}
      <g fill="none" stroke="var(--color-accent)" stroke-width="2" opacity="0.45" stroke-linecap="round">
        <path d="M210 150 C 300 110, 330 80, 388 80" />
        <path d="M214 190 C 305 190, 330 190, 388 190" />
        <path d="M210 230 C 300 270, 330 300, 388 300" />
      </g>

      {/* Manuskrypt / kartka pracy */}
      <g transform="translate(44 96)">
        <rect width="170" height="200" rx="14" fill="url(#hero-doc)" stroke="var(--color-border)" stroke-width="1.5" />
        {/* zagięty róg */}
        <path d="M150 0 L170 20 L150 20 Z" fill="var(--color-border)" opacity="0.6" />
        {/* tytuł */}
        <rect x="22" y="30" width="92" height="12" rx="3" fill="var(--color-text)" opacity="0.85" />
        {/* linijki tekstu */}
        <g fill="var(--color-text-muted)" opacity="0.38">
          <rect x="22" y="58" width="126" height="6" rx="3" />
          <rect x="22" y="74" width="118" height="6" rx="3" />
          <rect x="22" y="90" width="126" height="6" rx="3" />
          <rect x="22" y="106" width="96" height="6" rx="3" />
        </g>
        {/* akcentowy blok (rozdział) */}
        <rect x="22" y="128" width="126" height="40" rx="8" fill="var(--color-accent)" opacity="0.1" />
        <rect x="34" y="142" width="58" height="7" rx="3" fill="var(--color-accent)" />
        <rect x="34" y="155" width="92" height="5" rx="2" fill="var(--color-accent)" opacity="0.6" />
      </g>

      {/* Pióro nad dokumentem */}
      <g transform="translate(150 70) rotate(40)" stroke="url(#hero-accent)" stroke-width="6" stroke-linecap="round" fill="none">
        <path d="M0 0 L0 46" />
        <path d="M-7 38 L0 52 L7 38 Z" fill="url(#hero-accent)" stroke="none" />
      </g>

      {/* Trzy węzły ścieżek */}
      <g>
        {/* 1 — poradnik (book) */}
        <g transform="translate(360 56)">
          <rect width="84" height="48" rx="12" fill="var(--color-bg-elevated)" stroke="var(--color-accent)" stroke-width="1.5" />
          <g transform="translate(16 12)" stroke="var(--color-accent)" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 3C10 2 7 1.5 4 1.5H1.5v13H4c3 0 5.5.5 8 1.5" />
            <path d="M12 3c2-1 5-1.5 8-1.5h2.5v13H20c-3 0-5.5.5-8 1.5" />
            <path d="M12 3v13" />
          </g>
        </g>
        {/* 2 — dokument (file) */}
        <g transform="translate(360 166)">
          <rect width="84" height="48" rx="12" fill="var(--color-bg-elevated)" stroke="var(--color-accent)" stroke-width="1.5" />
          <g transform="translate(20 11)" stroke="var(--color-accent)" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round">
            <path d="M9 0H2a1.6 1.6 0 0 0-1.6 1.6v22.8A1.6 1.6 0 0 0 2 26h10a1.6 1.6 0 0 0 1.6-1.6V4z" />
            <path d="M9 0v4h4" />
            <path d="M4 13h6" /><path d="M4 17h4" />
          </g>
        </g>
        {/* 3 — AI (chip) */}
        <g transform="translate(360 276)">
          <rect width="84" height="48" rx="12" fill="var(--color-bg-elevated)" stroke="var(--color-accent-secondary)" stroke-width="1.5" />
          <g transform="translate(28 12)" stroke="var(--color-accent-secondary)" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round">
            <rect x="3" y="3" width="18" height="18" rx="3" />
            <rect x="8" y="8" width="8" height="8" rx="1.5" />
            <path d="M8 0v3M16 0v3M8 21v3M16 21v3M0 8h3M0 16h3M21 8h3M21 16h3" />
          </g>
        </g>
      </g>

      {/* drobny pływający akcent */}
      <circle cx="60" cy="70" r="6" fill="var(--color-accent-secondary)" opacity="0.8" />
    </svg>
  )}

  {variant === "minimal" && (
    <svg viewBox="0 0 480 360" class="h-auto w-full" role="img" aria-label="Ilustracja">
      <defs>
        <radialGradient id="hero-bg-min" cx="50%" cy="50%" r="60%">
          <stop offset="0%" stop-color="var(--color-accent)" stop-opacity="0.2" />
          <stop offset="100%" stop-color="var(--color-accent)" stop-opacity="0" />
        </radialGradient>
      </defs>
      <rect width="480" height="360" fill="url(#hero-bg-min)" />
      <circle cx="240" cy="180" r="80" fill="var(--color-accent)" opacity="0.14" />
      <circle cx="240" cy="180" r="40" fill="var(--color-accent)" />
    </svg>
  )}
</div>
