---
import type { Post } from "../lib/posts";
import { formatDatePl, readingTimeFromBody } from "../lib/posts";
import { CLUSTERS } from "../config/clusters";
import Icon from "./Icon.astro";

interface Props {
  post: Post;
  featured?: boolean;
}
const { post, featured = false } = Astro.props;
const c = CLUSTERS[post.data.cluster];
const href = `/blog/${post.id}/`;
const rt = readingTimeFromBody(post.body);
---

<article
  class:list={[
    "group relative flex flex-col rounded-2xl border border-[var(--color-border)] bg-[var(--color-bg-elevated)] p-6 transition-all duration-200 hover:-translate-y-0.5 hover:border-[var(--color-accent)]/40 hover:shadow-md",
    featured && "sm:col-span-2",
  ]}
>
  <div class="flex items-center gap-2 text-xs">
    <span class="inline-flex items-center gap-1.5 rounded-full bg-[var(--color-accent)]/10 px-2.5 py-1 font-semibold text-[var(--color-accent)]">
      <Icon name={c.icon} class="h-3.5 w-3.5" />
      {c.short}
    </span>
    <span class="text-[var(--color-text-faint)]">{rt}</span>
  </div>

  <h3 class="mt-4 text-xl font-bold leading-snug tracking-tight">
    <a href={href} class="text-[var(--color-text)] no-underline after:absolute after:inset-0 group-hover:text-[var(--color-accent)]">
      {post.data.title}
    </a>
  </h3>

  <p class="mt-2 line-clamp-3 text-[0.9375rem] leading-relaxed text-[var(--color-text-muted)]">
    {post.data.description}
  </p>

  <div class="mt-5 flex items-center justify-between pt-2 text-xs text-[var(--color-text-faint)]">
    <time datetime={post.data.pubDate.toISOString()}>{formatDatePl(post.data.pubDate)}</time>
    <span class="inline-flex items-center gap-1 font-medium text-[var(--color-accent)]">
      Czytaj <Icon name="arrow-right" class="h-3.5 w-3.5" />
    </span>
  </div>
</article>
