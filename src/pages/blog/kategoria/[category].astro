---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import Header from "../../../components/Header.astro";
import Footer from "../../../components/Footer.astro";
import ArticleCard from "../../../components/ArticleCard.astro";
import IconBadge from "../../../components/IconBadge.astro";
import Icon from "../../../components/Icon.astro";
import { getPostsByCluster } from "../../../lib/posts";
import { CLUSTERS, CLUSTER_ORDER, type ClusterKey } from "../../../config/clusters";
import { siteConfig } from "../../../config/site";

export async function getStaticPaths() {
  return CLUSTER_ORDER.map((key) => ({ params: { category: key }, props: { key } }));
}

interface Props { key: ClusterKey }
const { key } = Astro.props;
const c = CLUSTERS[key];
const posts = await getPostsByCluster(key);

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: `${c.label} — ${siteConfig.name}`,
  description: c.description,
  url: `${siteConfig.url}/blog/kategoria/${key}`,
  inLanguage: "pl-PL",
};
---

<BaseLayout
  title={`${c.label} — blog`}
  description={c.description}
  jsonLd={jsonLd}
>
  <Header />
  <main id="main">
    <section class="border-b border-[var(--color-border)]">
      <div class="mx-auto max-w-6xl px-4 py-14 sm:px-6 lg:px-8 lg:py-16">
        <nav aria-label="Okruszki" class="flex items-center gap-1.5 text-sm text-[var(--color-text-faint)]">
          <a href="/blog" class="no-underline hover:text-[var(--color-text)]">Blog</a>
          <span>/</span>
          <span class="text-[var(--color-text-muted)]">{c.label}</span>
        </nav>
        <div class="mt-5 flex items-start gap-4">
          <IconBadge icon={c.icon} tone="accent" size="lg" />
          <div>
            <h1 class="text-[length:var(--text-fs-h1)] font-bold leading-[1.1] tracking-tight">{c.label}</h1>
            <p class="mt-3 max-w-2xl text-lg text-[var(--color-text-muted)]">{c.description}</p>
          </div>
        </div>

        {/* Pozostałe kategorie */}
        <div class="mt-8 flex flex-wrap gap-2">
          {CLUSTER_ORDER.map((k) => (
            <a
              href={`/blog/kategoria/${k}/`}
              class:list={[
                "inline-flex items-center gap-1.5 rounded-full border px-3.5 py-1.5 text-sm font-medium no-underline transition-colors",
                k === key
                  ? "border-[var(--color-accent)] bg-[var(--color-accent)]/10 text-[var(--color-accent)]"
                  : "border-[var(--color-border)] bg-[var(--color-bg-elevated)] text-[var(--color-text-muted)] hover:text-[var(--color-text)]",
              ]}
            >
              <Icon name={CLUSTERS[k].icon} class="h-4 w-4" />
              {CLUSTERS[k].label}
            </a>
          ))}
        </div>
      </div>
    </section>

    <section class="mx-auto max-w-6xl px-4 py-14 sm:px-6 lg:px-8 lg:py-20">
      {posts.length === 0 ? (
        <div class="rounded-2xl border border-dashed border-[var(--color-border)] bg-[var(--color-bg-elevated)] p-10 text-center">
          <h2 class="text-xl font-bold tracking-tight">Wkrótce artykuły w tej kategorii</h2>
          <p class="mx-auto mt-3 max-w-md text-[var(--color-text-muted)]">
            Ta sekcja dopiero się zapełnia. Wróć niedługo lub przejrzyj
            <a href="/blog" class="ml-1 font-medium text-[var(--color-accent)] no-underline hover:underline">wszystkie artykuły</a>.
          </p>
        </div>
      ) : (
        <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
          {posts.map((p) => <ArticleCard post={p} />)}
        </div>
      )}
    </section>
  </main>
  <Footer />
</BaseLayout>
